{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "cborg/lbl/claude-opus-4-6",
      "ultrawork": {
        "model": "cborg/lbl/claude-opus-4-6",
        "variant": "max"
      }
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "cborg/lbl/claude-sonnet-4-6"
      ]
    },
    "librarian": {
      "model": "openai/gpt-5-mini",
      "fallback_models": [
        "openai/gpt-5-nano"
      ]
    },
    "explore": {
      "model": "openai/gpt-5-mini",
      "fallback_models": [
        "openai/gpt-5-nano"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5-nano"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "openai/gpt-5-mini",
      "fallback_models": [
        "openai/gpt-5-nano"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "cborg/lbl/claude-sonnet-4-6"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "cborg/lbl/claude-opus-4-6"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "cborg/lbl/claude-sonnet-4-6"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "cborg/lbl/claude-sonnet-4-6"
      ]
    }
  },
  "background_task": {
    "providerConcurrency": {
      "cborg": 1,
      "openai": 4
    },
    "modelConcurrency": {
      "cborg/lbl/claude-opus-4-6": 1
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "notify_on_fallback": true
  },
  "experimental": {
    "aggressive_truncation": true
  }
}
