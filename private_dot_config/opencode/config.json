{
	"$schema": "https://opencode.ai/config.json",
	"autoshare": false,
	"autoupdate": false,
	"model": "cborg/lbl/claude-sonnet-4-6",
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"webfetch": "allow",
		"external_directory": "ask"
	},
	"instructions": ["~/.config/opencode/AGENTS.md"],
	"tools": {
		"bash": true,
		"edit": true
	},
	"mcp": {
		"context7": {
			"type": "local",
			"command": ["npx", "-y", "@upstash/context7-mcp"]
		}
	},
	"provider": {
		"cborg": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "CBorg API",
			"options": {
				"baseURL": "https://api.cborg.lbl.gov",
				"apiKey": "{env:CBORG_API_KEY}"
			},
			"models": {
				"lbl/cborg-coder": {
					"id": "lbl/cborg-coder",
					"name": "CBorg Coder",
					"reasoning": true,
					"tool_call": true,
					"limit": {
						"context": 131072,
						"output": 131072
					}
				},
				"lbl/claude-sonnet-4-6": {
					"id": "claude-sonnet-4-6",
					"name": "Claude Sonnet 4.6",
					"reasoning": true,
					"tool_call": true
				},
				"lbl/claude-opus-4-6": {
					"id": "claude-opus-4-6",
					"name": "Claude Opus 4.6",
					"reasoning": true,
					"tool_call": true,
					"options": {
						"reasoningEffort": "high",
						"textVerbosity": "low",
						"reasoningSummary": "auto"
					}
				},
				"lbl/gpt-5.3-codex": {
					"id": "gpt-5.3-codex",
					"name": "GPT 5.3 codex",
					"reasoning": true,
					"tool_call": true
				},
				"lbl/gemini-3.1-pro": {
					"id": "gemini-3.1-pro",
					"name": "Gemini 3.1 Pro",
					"reasoning": true,
					"tool_call": true,
					"options": {
						"reasoningEffort": "high",
						"textVerbosity": "low",
						"reasoningSummary": "auto"
					}
				}
			}
		}
	}
}
