{
	"$schema": "https://opencode.ai/config.json",
	"autoshare": false,
	"autoupdate": false,
	"default_agent": "plan",
	"model": "openai/gpt-5.4",
	"plugin": [
		"opencode-pty",
		"@franlol/opencode-md-table-formatter@latest",
		"@mohak34/opencode-notifier@latest",
		"opencode-background-agents",
		"@plannotator/opencode@latest"
	],
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"webfetch": "allow",
		"external_directory": "ask"
	},
	"instructions": ["~/.config/opencode/AGENTS.md"],
	"tools": {
		"bash": true,
		"edit": true,
		"playwright_*": false,
		"serena_*": false
	},
	"mcp": {
		"sequential-thinking": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"environment": {
				"DISABLE_THOUGHT_LOGGING": "true"
			},
			"enabled": true
		},
		"gh_grep": {
			"type": "remote",
			"url": "https://mcp.grep.app"
		},
		"playwright": {
			"type": "local",
			"command": ["npx", "-y", "@playwright/mcp@latest"],
			"enabled": true
		},
		"serena": {
			"type": "local",
			"command": [
				"uvx",
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server"
			],
			"enabled": true,
			"timeout": 15000
		}
	},
	"agent": {
		"build": {
			"model": "openai/gpt-5.4",
			"variant": "medium",
			"tools": {
				"playwright_*": true,
				"serena_*": true
			}
		},
		"plan": {
			"model": "openai/gpt-5.4",
			"variant": "high",
			"tools": {
				"serena_*": true
			}
		}
	},
	"provider": {
		"cborg": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "CBorg API",
			"options": {
				"baseURL": "https://api.cborg.lbl.gov",
				"apiKey": "{env:CBORG_API_KEY}"
			},
			"models": {
				"lbl/cborg-coder": {
					"id": "lbl/cborg-coder",
					"name": "CBorg Coder",
					"reasoning": true,
					"tool_call": true,
					"limit": {
						"context": 131072,
						"output": 131072
					}
				},
				"lbl/claude-sonnet-4-6": {
					"id": "claude-sonnet-4-6",
					"name": "Claude Sonnet 4.6",
					"reasoning": true,
					"tool_call": true
				},
				"lbl/claude-opus-4-6": {
					"id": "claude-opus-4-6",
					"name": "Claude Opus 4.6",
					"reasoning": true,
					"tool_call": true,
					"options": {
						"reasoningEffort": "high",
						"textVerbosity": "low"
					}
				},
				"lbl/gpt-5.3-codex": {
					"id": "gpt-5.3-codex",
					"name": "GPT 5.3 codex",
					"reasoning": true,
					"tool_call": true
				},
				"lbl/gemini-3.1-pro": {
					"id": "gemini-3.1-pro",
					"name": "Gemini 3.1 Pro",
					"reasoning": true,
					"tool_call": true,
					"options": {
						"reasoningEffort": "high",
						"textVerbosity": "low"
					}
				}
			}
		}
	}
}
