status is-interactive; or return

if set -q AGENT_SHELL
    return
end

if set -q CLAUDECODE
    if test "$CLAUDECODE" = "1"
        return
    end
end

if set -q CURSOR_AGENT
    return
end

if set -q GEMINI_CLI
    return
end

if test -x /home/linuxbrew/.linuxbrew/bin/brew
    /home/linuxbrew/.linuxbrew/bin/brew shellenv | source
end

if test -f /global/homes/d/dkishore/.pixi/envs/ruby/share/rubygems/gems/tmuxinator-3.3.5/bin/tmuxinator
    fish_add_path -a /global/homes/d/dkishore/.pixi/envs/ruby/share/rubygems/gems/tmuxinator-3.3.5/bin
end

if command -q vivid
    set -gx LS_COLORS (vivid generate catppuccin-mocha)
end

set -gx CARAPACE_BRIDGES zsh,fish,bash,inshellisense

if command -q carapace
    carapace _carapace | source
end

if command -q zoxide
    zoxide init fish | source
end

if command -q atuin
    set -gx ATUIN_NOBIND true
    atuin init fish | source
end

if command -q tv
    tv init fish | source
end

if command -q oh-my-posh
    oh-my-posh init fish --config $HOME/.config/ohmyposh/config.json | source
end

if command -q direnv
    direnv hook fish | source
end

if command -q asdf
    set -l asdf_shims
    if set -q ASDF_DATA_DIR
        set asdf_shims "$ASDF_DATA_DIR/shims"
    else
        set asdf_shims "$HOME/.asdf/shims"
    end

    if not contains "$asdf_shims" $PATH
        set -gx --prepend PATH "$asdf_shims"
    end
end

{{- if eq .chezmoi.hostname "tsuki" }}
fish_add_path -a "{{ .chezmoi.homeDir }}/.juliaup/bin"
{{- end }}
