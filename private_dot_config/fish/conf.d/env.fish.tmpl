# Shared environment for interactive shells and agent shells.

set -gx EDITOR nvim
set -gx USE_EDITOR $EDITOR
set -gx VISUAL $EDITOR
{{- if eq .chezmoi.hostname "tsuki" }}
set -gx BROWSER helium-browser
{{- end }}
set -gx GIT_PAGER delta
set -gx FZF_DEFAULT_OPTS "\
    --height 40% --reverse --preview 'bat --style=numbers --color=always --line-range :100 {}'\
    --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
    --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
    --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"

fish_add_path -p "$HOME/.pixi/bin" "$HOME/.bun/bin"
fish_add_path -a "$HOME/.local/bin" "/var/lib/flatpak/exports/bin" "$HOME/npm-global/bin"

if test -f "$HOME/.secrets/openai.txt"
    set -gx OPENAI_API_KEY (string trim -- (cat "$HOME/.secrets/openai.txt"))
end

if test -f "$HOME/.secrets/anthropic.txt"
    set -gx ANTHROPIC_API_KEY (string trim -- (cat "$HOME/.secrets/anthropic.txt"))
end

if test -f "$HOME/.secrets/gemini.txt"
    set -gx GEMINI_API_KEY (string trim -- (cat "$HOME/.secrets/gemini.txt"))
end

if test -f "$HOME/.secrets/tavily.txt"
    set -gx TAVILY_API_KEY (string trim -- (cat "$HOME/.secrets/tavily.txt"))
end

if test -f "$HOME/.secrets/cborg.txt"
    set -gx CBORG_API_KEY (string trim -- (cat "$HOME/.secrets/cborg.txt"))
end

if test -f "$HOME/.secrets/context7.txt"
    set -gx CONTEXT7_API_KEY (string trim -- (cat "$HOME/.secrets/context7.txt"))
end

set -gx ENABLE_LSP_TOOL 1
set -gx DISABLE_NON_ESSENTIAL_MODEL_CALLS 1
set -gx DISABLE_TELEMETRY 1

if test (hostname) = "mac148593"
    set -l cert_file "$HOME/corporate-certs.pem"

    if not test -f "$cert_file"
        security find-certificate -a -p /Library/Keychains/System.keychain >"$cert_file" 2>/dev/null
    end

    if test -f "$cert_file"
        set -gx NODE_EXTRA_CA_CERTS "$cert_file"
    end
end

